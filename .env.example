# ─────────────────────────────────────────────────────────────
# AERP environment. Copy to `.env` and fill in. NEVER commit `.env`.
# ─────────────────────────────────────────────────────────────

# App
AERP_ENV=development
AERP_DEBUG=true
AERP_SECRET_KEY=change-me-to-a-long-random-string
AERP_API_V1_PREFIX=/api/v1
# Comma-separated list of allowed CORS origins for the frontend
AERP_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# PostgreSQL (compose provides these defaults; override for production)
POSTGRES_USER=aerp
POSTGRES_PASSWORD=aerp
POSTGRES_DB=aerp
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# If set, DATABASE_URL overrides the individual POSTGRES_* vars above.
# DATABASE_URL=postgresql+psycopg://aerp:aerp@postgres:5432/aerp

# Redis (broker + cache + pub/sub)
REDIS_URL=redis://redis:6379/0

# Seed control
AERP_SEED_ON_STARTUP=true

# PSX data folders/files (see docs). CSV of PSX insider transactions (from the
# Sarmaaya scraper, scripts/scrape_psx_insider.py):
AERP_PSX_INSIDER_CSV=data/psx_insider.csv

# Auth / JWT
AERP_JWT_ALGORITHM=HS256
AERP_ACCESS_TOKEN_EXPIRE_MINUTES=1440
# First-superuser bootstrap (created on startup if the email doesn't exist).
# Leave blank to skip; set both to enable the admin ingestion endpoints.
AERP_ADMIN_EMAIL=
AERP_ADMIN_PASSWORD=

# Rate limiting (requests per minute per client IP; fails open if Redis is down)
AERP_RATE_LIMIT_PER_MINUTE=120

# ─────────────────────────────────────────────────────────────
# Data providers: NONE REQUIRED. The default routing is 100% free and keyless
# (yfinance for everything + Binance for crypto + PSX portal scrape).
#
# The keys below are OPTIONAL — for paid providers (FMP/TwelveData/EODHD) that
# exist as drop-ins but are NOT wired into the default routing. Leave blank.
# ─────────────────────────────────────────────────────────────
FMP_API_KEY=
TWELVE_DATA_API_KEY=
EODHD_API_KEY=
